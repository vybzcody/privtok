{
    "name": "private-auction-react",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "webpack --config webpack.config.js",
        "build:vite": "vite build",
        "build:deploy": "vite build && cp _headers _redirects dist/",
        "dev:webpack": "webpack-dev-server",
        "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0 && prettier . --check",
        "pretty": "prettier . --write",
        "preview": "vite preview",
        "deploy": "gh-pages -d dist",
        "deploy:surge": "vite build && cp _headers _redirects dist/ && surge ./dist --domain privtok-v2.surge.sh"
    },
